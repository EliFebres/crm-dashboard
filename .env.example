# =============================================================================
# CRM Dashboard - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# .env is gitignored and should never be committed.
# =============================================================================

# Required: Absolute path to the folder where the SQLite database files live.
# The folder and database files (engagements.sqlite, users.sqlite,
# activity.sqlite) are created automatically on first run.
#
# IMPORTANT (reliability): keep the LIVE database on the server's LOCAL disk —
# never on an SMB/network share. SQLite file locking over a network share is
# unreliable and risks corruption. Point BACKUP_DIR (below) at the network share
# instead, so backups are replicated off-box while the live DB stays local.
#
# Production (local disk on the server):
#   SQLITE_DIR=C:/CRM/data
#
# Local development:
#   SQLITE_DIR=./data
SQLITE_DIR=

# Required: Secret key for signing JWT session tokens.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be at least 32 characters. Never commit this value.
JWT_SECRET=

# Required for db:backup and db:restore scripts (and the daily auto-backup).
# Absolute path to the directory where database backups will be stored — this is
# the right place for the network share, so snapshots are replicated off the
# server. Backups use SQLite's online backup API, so they're safe to take while
# the app is running.
#
# Example (network share):
#   BACKUP_DIR=J:/CRM/backups
BACKUP_DIR=
